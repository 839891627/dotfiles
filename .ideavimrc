let mapleader=' '
set surround
set easymotion

set encoding=utf-8
set nu
set relativenumber
set incsearch
"set ignorecase
" set ic
set hlsearch
set nowrapscan             
set showmatch
nnoremap 0 ^
nnoremap ,z :wq<CR>
nnoremap <esc> :nohl<cr>
nnoremap <esc> :nohls<cr>
inoremap zz <esc>zz
inoremap jk <esc>
nnoremap Y yg_
inoremap <C-j> <Down>
inoremap <C-k> <Up>
inoremap <C-h> <Left>
inoremap <C-l> <Right>
imap <M-l> <Esc>A
imap <M-h> <Esc>I

nnoremap zh :action PreviousTab<CR>
nnoremap zl :action NextTab<CR>
nnoremap ,q :action CloseAllEditors<CR> 

nnoremap <C-O> :action Back<CR>
nnoremap <C-I> :action Forward<CR>



" normal模式下 Ni$ <esc> 连续插入N个$, 比如 9ia<esc> 连续插入9个a，这在写分割线的时候很方便
" nmap <leader>f :action KJumpAction<cr>
nmap <C-,> :action KJumpAction<cr>
nmap <leader>w :action KJumpAction.Word0<cr>
nmap <C-;> :action KJumpAction.Word0<cr>
nmap <leader>l :action KJumpAction.Line<cr>

nnoremap <Space>a :action GotoAction<CR>
" nnoremap <Space>c :action GotoClass<CR>
nnoremap <Space>e :action RecentChangedFiles<CR>
nnoremap <Space><Space>e :action SelectInProjectView<CR>
nnoremap <Space>f :action FindInPath<CR>
vnoremap <Space>f :action FindInPath<CR>
nnoremap <Space>g :action Annotate<CR>
nnoremap <Space>m :action FileStructurePopup<CR>
nnoremap <Space>s :action SurroundWith<CR>
vnoremap <Space>s :action SurroundWith<CR>
nnoremap <Space>u :action FindUsages<CR>
nnoremap <Space>t :action Refactorings.QuickListPopupAction<CR>
nnoremap <Space>r :action RenameElement<CR>
nnoremap <Space>o :action OpenEditorInOppositeTabGroup<CR>
nnoremap mn :action ShowBookmarks<CR>
nnoremap mm :action ToggleBookmark<CR>

" Window operation
nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-h> <C-W>h
nnoremap <C-l> <C-W>l
nnoremap <tab> :action NextSplitter<CR>

" inoremap <C-j> <Down>
" inoremap <C-k> <Up>
" inoremap <C-h> <Left>
" inoremap <C-l> <Right>

