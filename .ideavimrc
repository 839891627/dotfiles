let mapleader=' '
set surround
set easymotion

set encoding=utf-8
set nu
set relativenumber
set incsearch
set ignorecase
" set ic
set hlsearch
set nowrapscan             
set showmatch
nnoremap 0 ^
nnoremap ,z :wq<CR>
nnoremap <esc> :nohl<cr>
nnoremap <esc> :nohls<cr>
inoremap zz <esc>zz
inoremap jk <esc>
nnoremap Y yg_
inoremap <C-j> <Down>
inoremap <C-k> <Up>

nnoremap zh :action PreviousTab<CR>
nnoremap zl :action NextTab<CR>
nnoremap ,q :action CloseAllEditors<CR> 
nnoremap <tab> :action NextSplitter<CR>

nnoremap <C-O> :action Back<CR>
nnoremap <C-I> :action Forward<CR>

nnoremap <space><space>u :action FindUsages<CR>
nnoremap <space><space>f :action FileStructurePopup<CR>
nnoremap <space><space>e :action SelectInProjectView<CR>
nnoremap <space><space>s :action IntroduceVariable<CR>
nnoremap <space><space>r :action RenameElement<CR>
nnoremap <space><space>o :action OpenEditorInOppositeTabGroup<CR>
nnoremap <space><space>t :action Refactorings.QuickListPopupAction<CR>
nnoremap <space><space>g :action Annotate<CR>

" normal模式下 Ni$ <esc> 连续插入N个$, 比如 9ia<esc> 连续插入9个a，这在写分割线的时候很方便
nmap <leader>f :action KJumpAction<cr>
nmap <leader>w :action KJumpAction.Word0<cr>
nmap <leader>l :action KJumpAction.Line<cr>
