let mapleader=' '
set surround
set easymotion

set encoding=utf-8
set nu
set relativenumber
set incsearch
set ignorecase
" set ic
set hlsearch
set nowrapscan             
set showmatch
nnoremap 0 ^
nnoremap ,z :wq<CR>
nnoremap <esc> :nohl<cr>
nnoremap <esc> :nohls<cr>
inoremap zz <esc>zz
inoremap jk <esc>
nnoremap Y yg_
inoremap <C-j> <Down>
inoremap <C-k> <Up>

nnoremap zh :action PreviousTab<CR>
nnoremap zl :action NextTab<CR>
nnoremap ,q :action CloseAllEditors<CR> 
nnoremap <tab> :action NextSplitter<CR>

nnoremap <C-O> :action Back<CR>
nnoremap <C-I> :action Forward<CR>



" normal模式下 Ni$ <esc> 连续插入N个$, 比如 9ia<esc> 连续插入9个a，这在写分割线的时候很方便
" nmap <leader>f :action KJumpAction<cr>
nmap <C-,> :action KJumpAction<cr>
nmap <leader>w :action KJumpAction.Word0<cr>
nmap <C-;> :action KJumpAction.Word0<cr>
nmap <leader>ll :acion KJumpAction.Line<cr>

" built in search looks better
nnoremap / :action Find<CR>
" but preserve ideavim search
nnoremap <Space>/ /

nnoremap <Space>c :action ShowPopupMenu<CR>
nnoremap <Space>m :action FileStructurePopup<CR>
nnoremap <Space><Space>f :action GotoFile<CR>
nnoremap <Space><Space>c :action GotoClass<CR>
nnoremap <Space><Space>a :action GotoAction<CR>
nnoremap <Space><Space>g :action Annotate<CR>
nnoremap <Space><Space>e :action SelectInProjectView<CR>
nnoremap <Space>f :action FindInPath<CR>
nnoremap <Space>e :action RecentFiles<CR>
nnoremap <Space>u :action FindUsages<CR>
nnoremap <Space>t :action Refactorings.QuickListPopupAction<CR>
nnoremap <Space>r :action RenameElement<CR>
nnoremap <Space>o :action OpenEditorInOppositeTabGroup<CR>

" Window operation
nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-h> <C-W>h
nnoremap <C-l> <C-W>l

inoremap <C-j> <Down>
inoremap <C-k> <Up>
inoremap <C-h> <Left>
inoremap <C-l> <Right>
